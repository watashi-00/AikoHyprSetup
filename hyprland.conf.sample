## Hyprland sample config for a pink desktop layout
# This is a SAFE example. Copy relevant lines into ~/.config/hypr/hyprland.conf
# and adapt paths/program names as needed. Do NOT overwrite your working config
# unless you have a backup.

# --- Basic modifiers ---
mapmod = SUPER

# --- Appearance ---
decoration:rounding = 12
decoration:border_size = 2
decoration:active_border = #f5c2e7
decoration:inactive_border = #2f2730

# Gaps and padding
gaps_in = 10
gaps_out = 16
window_padding = 8

# --- Autostart ---
# Left dock (second Waybar instance - create config-left.jsonc)
exec-once = waybar --config ~/.config/waybar/config-left.jsonc --style ~/.config/waybar/style.css
# Main top bar (already configured)
exec-once = waybar --config ~/.config/waybar/config.jsonc --style ~/.config/waybar/style.css
# Bottom centered bar (footer) - create config-bottom.jsonc
exec-once = waybar --config ~/.config/waybar/config-bottom.jsonc --style ~/.config/waybar/style.css
# Wallpaper
exec-once = hyprpaper --random-fill

# --- Window rules for widgets (telinhas) ---
# Keep small widgets, popups and bar windows floating on a dedicated workspace
windowrulev2 = float,workspace=__floats__
# Example: make pavucontrol float
windowrule = float,app:pexec:pavucontrol
# Example: force custom widget windows with title "Widget" to float
# windowrulev2 = float,workspace=__floats__,title="Widget"

# --- Positioning helpers ---
# You can create named workspaces and move apps there. Examples:
# windowrulev2 = move_to_workspace,workspace:3,app:class:Firefox

# --- Example keybinds ---
bind = SUPER+f, togglefloating
bind = SUPER+Return, exec, alacritty

# --- Notes ---
# 1) Create the additional Waybar configs referenced above:
#    - ~/.config/waybar/config-left.jsonc (vertical dock)
#    - ~/.config/waybar/config-bottom.jsonc (bottom centered pill)
# 2) If you want precise positioning for specific widget windows, run
#    `xprop` or `hyprctl activewindow` to inspect window class/title and
#    add targeted windowrules. Test rules incrementally.



